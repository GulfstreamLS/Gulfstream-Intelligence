# App
APP_NAME="Gulfstream Intelligence"
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gulfstream

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6

# GCP (leave empty for local dev)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCS_BUCKET_NAME=
